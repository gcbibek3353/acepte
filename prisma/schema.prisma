  userId              String
  passageId           String
  selectedOptionIndex Int // Index of the option selected by user
  totalScore          Float?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  user    User                              @relation(fields: [userId], references: [id], onDelete: Cascade)
  passage ListeningSelectMissingWordPassage @relation(fields: [passageId], references: [id], onDelete: Cascade)

  @@map("listening_select_missing_word_answer")
}

