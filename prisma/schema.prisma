// Highlight Incorrect Words (Listening)
model ListeningHighlightIncorrectWordsPassage {
  id         String     @id @default(cuid())
  questionId String     @unique
  title      String
  audioUrl   String // URL/path to the audio file
  passage    String     @db.Text // The full passage shown to user
  difficulty Difficulty @default(MEDIUM)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  // Relations
  incorrectWords ListeningIncorrectWord[]
  answers        ListeningHighlightIncorrectWordsAnswer[]
  bookmarks      ListeningHighlightIncorrectWordsBookmark[]

  @@map("listening_highlight_incorrect_words_passage")
}

model ListeningIncorrectWord {
  id          String                                  @id @default(cuid())
  word        String // Incorrect word in passage
  position    Int // Index/position of word in passage (helps to highlight)
  passageId   String
  passage     ListeningHighlightIncorrectWordsPassage @relation(fields: [passageId], references: [id], onDelete: Cascade)
  createdAt   DateTime                                @default(now())

  @@map("listening_incorrect_word")
}

