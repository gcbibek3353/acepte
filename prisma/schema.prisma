  selectedWords Json // [{"word" : "school" , "position" : 4},{}]
  totalScore    Float?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  user    User                                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  passage ListeningHighlightIncorrectWordsPassage @relation(fields: [passageId], references: [id], onDelete: Cascade)

  @@map("listening_highlight_incorrect_words_answer")
}

