// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean
  image         String?
  createdAt     DateTime
  updatedAt     DateTime
  sessions      Session[]
  accounts      Account[]

  write_essay_answers WriteEssayAnswer[]
  summarize_written_text_answers SummarizeWrittenTextAnswer[]

  writeEssayBookmark    WriteEssayBookMark[]
  summarizeWrittenTextBookmark SummarizeWrittenTextBookMark[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

// Writing specific models

model WriteEssayQuestion {
  id                String     @id @default(cuid())
  questionId        String     @unique // Your custom unique identifier
  essayTitle       String
  essay_description String
  difficulty        Difficulty @default(MEDIUM)
  min_word_limit    Int?
  max_word_limit    Int?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  isActive          Boolean    @default(true)

  // Relations
  answers   WriteEssayAnswer[]
  bookmarks WriteEssayBookMark[]

  @@map("write_essay_question")
}

model WriteEssayAnswer {
  id         String   @id @default(cuid())
  userId     String
  questionId String
  answer     String   @db.Text // Large text field for essay content
  wordCount  Int?
  timeSpent  Int? // in seconds
  score      Float? // nullable until graded
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  user     User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  question WriteEssayQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("write_essay_answer")
}

model WriteEssayBookMark {
  id         String   @id @default(cuid())
  userId     String
  questionId String
  createdAt  DateTime @default(now())

  // Relations
  user     User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  question WriteEssayQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
  @@map("write_essay_bookmark")
}

model SummarizeWrittenTextQuestion {
  id             String     @id @default(cuid())
  questionId     String     @unique // Your custom unique identifier
  textTitle     String
  passage        String     @db.Text // The text to be summarized
  difficulty     Difficulty @default(MEDIUM)
  min_word_limit Int?
  max_word_limit Int?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  isActive       Boolean    @default(true)

  // Relations
  answers   SummarizeWrittenTextAnswer[]
  summarizeWrittenTextBookmarks SummarizeWrittenTextBookMark[]

  @@map("summarize_written_text_question")
}

model SummarizeWrittenTextAnswer {
  id         String   @id @default(cuid())
  userId     String
  questionId String
  answer     String   @db.Text // Large text field for summary content
  wordCount  Int?
  timeSpent  Int? // in seconds
  score      Float? // nullable until graded
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  user     User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  question SummarizeWrittenTextQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("summarize_written_text_answer")
}

model SummarizeWrittenTextBookMark {
  id         String   @id @default(cuid())
  userId     String
  questionId String
  createdAt  DateTime @default(now())

  // Relations
  user     User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  question SummarizeWrittenTextQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
  @@map("summarize_written_text_bookmark")
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}
